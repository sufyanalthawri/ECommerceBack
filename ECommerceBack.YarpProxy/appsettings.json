{
  "Logging": {
    "LogLevel": {
      //"Default": "Error",
      //"Yarp.ReverseProxy": "Error",
      "Yarp.ReverseProxy.Forwarder.HttpForwarder": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "ecommerce-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ecommerce-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "instance1": {
            "Address": "https://localhost:5000/"
          },
          "instance2": {
            "Address": "https://localhost:5010/"
          },
          "instance3": {
            "Address": "https://localhost:5020/"
          }
        }
      }
    }
  }
}